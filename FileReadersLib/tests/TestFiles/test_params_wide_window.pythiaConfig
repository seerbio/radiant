# Text describing stuff

[General]
threadCount = 16
verbosity = 1
writePythiaDIA = true

[LibraryParams]
chargeStateMin = 1
chargeStateMax = 4
mzMinMS2 = 200.0
mzMaxMS2 = 1500.0
peptideLengthMin = 8
peptideLengthMax = 31
trancheSizeMax = 1e4

[MS1Params]
precursorExtractionWindowThomsons = 0.5
ms1ExtractionWidthPPM = 20.0

[MS2Params]
filterLengthIntegration = 6
filterLengthMS2 = 4
ionsSharedToReject = 2
ms2ExtractionWidthPPM = 21.0
minMs2FragCount = 3
scanTimeWindowStDevs = 4
subtractShadows = false
smoothCountMS2 = 2
stopThresholdFractionMS2 = 0.666
topNIntegrations = 5
maxAnchorColumnIndex = 6

[FdrParams]
percentFDR = 2.0
reportDecoys = true

[PeakIntegrationParams]
filterLength = 4
sigma = 1.1
signalToNoiseRatio = 2.1
smoothCount = 3

[FeatureFinderParams]
minScanCount = 4
skipScanCount = 4